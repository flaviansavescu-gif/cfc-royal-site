---
// Conducere.astro — pagina Consiliului Director (cu fotografii), parametrizată pe limbă.
import { leaders } from "../data/conducere";
import type { Lang } from "../i18n/ui";

interface Props { lang: Lang }
const { lang } = Astro.props;
const t = {
  ro: {
    eyebrow: "Organizația", title: "Conducere",
    intro: "Conducerea statutară și Consiliul Director al Club Federal Chinologic – Royal.",
    statutory: "Conducerea statutară",
    ga: "Adunarea Generală a Membrilor", gaDesc: "organul suprem de conducere",
    cd: "Consiliul Director", cdDesc: "organ executiv de conducere",
    boardTitle: "Consiliul Director", founder: "Membru fondator",
  },
  en: {
    eyebrow: "Organization", title: "Leadership",
    intro: "The statutory leadership and Board of Directors of the Royal Federal Canine Club.",
    statutory: "Statutory leadership",
    ga: "General Assembly of Members", gaDesc: "the supreme governing body",
    cd: "Board of Directors", cdDesc: "the executive governing body",
    boardTitle: "Board of Directors", founder: "Founding member",
  },
}[lang];
---
<section class="container conducere">
  <header class="conducere__head">
    <p class="eyebrow">{t.eyebrow}</p>
    <h1>{t.title}</h1>
    <p class="lead">{t.intro}</p>
  </header>

  <h2 class="conducere__sub">{t.statutory}</h2>
  <ul class="statutory" role="list">
    <li><strong>{t.ga}</strong> — {t.gaDesc}</li>
    <li><strong>{t.cd}</strong> — {t.cdDesc}</li>
  </ul>

  <h2 class="conducere__sub">{t.boardTitle}</h2>
  <div class="leaders">
    {leaders.map((m) => (
      <article class="leader">
        <img class="leader__photo" src={m.photo} alt={m.name} width="130" height="130" loading="lazy" />
        <div class="leader__body">
          <p class="leader__role">{m.role[lang]}{m.founder && <span class="leader__founder"> · {t.founder}</span>}</p>
          <h3 class="leader__name">{m.name}</h3>
          <ul class="leader__resp" role="list">
            {m.responsibilities[lang].map((r) => <li>{r}</li>)}
          </ul>
        </div>
      </article>
    ))}
  </div>
</section>

<style>
  .conducere { padding-block: clamp(2rem, 5vw, 3.5rem); max-width: 60rem; }
  .conducere__head { margin-bottom: 2.5rem; }
  .conducere__head h1 { color: var(--color-primary); }
  .conducere__head .lead { margin-top: 0.5rem; color: var(--color-text-muted); }
  .conducere__sub { color: var(--color-primary); font-size: var(--fs-600); margin: 2rem 0 1rem; padding-bottom: 0.4rem; border-bottom: 2px solid var(--color-border); }
  .statutory { display: flex; flex-direction: column; gap: 0.4rem; }
  .statutory li { color: var(--color-text); }

  .leaders { display: flex; flex-direction: column; gap: 1.25rem; }
  .leader {
    display: flex; gap: 1.25rem; align-items: flex-start;
    background: var(--color-surface); border: 1px solid var(--color-border); border-radius: var(--radius); padding: 1.25rem;
  }
  .leader__photo { width: 130px; height: 130px; object-fit: cover; border-radius: var(--radius); border: 1px solid var(--color-border); flex-shrink: 0; }
  .leader__role { font-size: var(--fs-300); font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; color: var(--color-accent-dark); }
  .leader__founder { color: var(--color-text-muted); font-weight: 600; text-transform: none; letter-spacing: 0; }
  .leader__name { font-size: var(--fs-600); color: var(--color-primary); margin: 0.15rem 0 0.6rem; }
  .leader__resp { display: flex; flex-direction: column; gap: 0.25rem; padding-left: 1.1rem; list-style: disc; }
  .leader__resp li { font-size: var(--fs-400); color: var(--color-text-muted); }

  @media (max-width: 560px) {
    .leader { flex-direction: column; align-items: center; text-align: center; }
    .leader__resp { text-align: left; }
  }
</style>
