---
// Card.astro — card reutilizabil (eveniment, știre, standard, afiliat...).
// Întreg cardul e un link (stretched-link prin ::after).
interface Props {
  title: string;
  href: string;
  meta?: string;
  excerpt?: string;
  tag?: string;
  demo?: boolean;
}
const { title, href, meta, excerpt, tag, demo = false } = Astro.props;
---
<article class="card">
  {tag && <span class="card__tag">{tag}</span>}
  <h3 class="card__title"><a href={href}>{title}</a></h3>
  {meta && <p class="card__meta">{meta}</p>}
  {excerpt && <p class="card__excerpt">{excerpt}</p>}
  {demo && <span class="card__demo" title="Exemplu de structură — se înlocuiește cu conținut real">demo</span>}
</article>

<style>
  .card {
    position: relative; display: flex; flex-direction: column; gap: 0.4rem;
    padding: 1.25rem; background: var(--color-surface);
    border: 1px solid var(--color-border); border-radius: var(--radius);
    transition: border-color 0.15s ease, box-shadow 0.15s ease, transform 0.15s ease;
  }
  .card:hover { border-color: var(--color-primary-light); box-shadow: 0 6px 20px rgba(0,0,0,0.06); transform: translateY(-2px); }
  .card__tag {
    align-self: flex-start; font-size: 0.72rem; font-weight: 700; text-transform: uppercase;
    letter-spacing: 0.05em; color: var(--color-primary); background: var(--color-surface-alt);
    padding: 0.2rem 0.55rem; border-radius: 999px;
  }
  .card__title { font-size: var(--fs-500); line-height: 1.25; color: var(--color-text); }
  .card__title a { color: inherit; text-decoration: none; }
  .card__title a::after { content: ""; position: absolute; inset: 0; } /* stretched link */
  .card__title a:hover { color: var(--color-primary); }
  .card__meta { font-size: var(--fs-300); color: var(--color-text-muted); }
  .card__excerpt { font-size: var(--fs-400); color: var(--color-text-muted); }
  .card__demo {
    position: absolute; top: 0.6rem; right: 0.6rem; font-size: 0.6rem; text-transform: uppercase;
    letter-spacing: 0.08em; color: var(--color-text-muted); opacity: 0.6;
  }
</style>
