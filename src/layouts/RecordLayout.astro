---
// RecordLayout.astro — șablon UNIC pentru pagina individuală a oricărei colecții
// (expoziții, arbitri, canise, standarde...). Wrap peste BaseLayout.
import BaseLayout from "./BaseLayout.astro";
import type { Lang } from "../i18n/ui";

interface Crumb { label: string; href: string }
interface MetaRow { label: string; value: string; wide?: boolean }

interface Props {
  lang: Lang;
  title: string;
  description?: string;
  image?: string;
  type?: "website" | "article";
  jsonLd?: Record<string, unknown>;
  eyebrow?: string;
  cover?: string;
  meta?: MetaRow[];
  breadcrumbs?: Crumb[];
}

const { lang, title, description, image, type = "article", jsonLd, eyebrow, cover, meta = [], breadcrumbs = [] } =
  Astro.props;
---
<BaseLayout title={title} description={description} lang={lang} image={image ?? cover} type={type} jsonLd={jsonLd}>
  <article class="record">
    <div class="container record__inner">
      {breadcrumbs.length > 0 && (
        <nav class="crumbs" aria-label="Breadcrumb">
          <ol role="list">
            {breadcrumbs.map((c, i) => (
              <li>
                {i < breadcrumbs.length - 1 ? <a href={c.href}>{c.label}</a> : <span aria-current="page">{c.label}</span>}
              </li>
            ))}
          </ol>
        </nav>
      )}

      <header class="record__head">
        {eyebrow && <p class="eyebrow">{eyebrow}</p>}
        <h1 class="record__title">{title}</h1>
      </header>

      {cover && <img class="record__cover" src={cover} alt="" loading="eager" />}

      {meta.length > 0 && (
        <dl class="record__meta">
          {meta.map((m) => (
            <div class={`record__meta-row${m.wide ? " record__meta-row--wide" : ""}`}>
              <dt>{m.label}</dt>
              <dd>{m.value}</dd>
            </div>
          ))}
        </dl>
      )}

      <div class="record__body flow">
        <slot />
      </div>
    </div>
  </article>
</BaseLayout>

<style>
  .record__inner { max-width: 56rem; padding-block: clamp(1.5rem, 4vw, 3rem); }

  .crumbs { font-size: var(--fs-300); margin-bottom: 1.25rem; }
  .crumbs ol { display: flex; flex-wrap: wrap; gap: 0.35rem; color: var(--color-text-muted); }
  .crumbs li:not(:last-child)::after { content: "/"; margin-left: 0.35rem; opacity: 0.5; }
  .crumbs a { color: var(--color-text-muted); text-decoration: none; }
  .crumbs a:hover { color: var(--color-primary); }

  .record__head { margin-bottom: 1.5rem; }
  .record__title { color: var(--color-primary); margin-top: 0.25rem; }
  .record__cover { width: 100%; border-radius: var(--radius); border: 1px solid var(--color-border); margin-bottom: 1.5rem; }

  .record__meta {
    display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 0.75rem 1.5rem;
    padding: 1.25rem; margin-bottom: 2rem;
    background: var(--color-surface-alt); border: 1px solid var(--color-border); border-radius: var(--radius);
  }
  .record__meta-row { min-width: 0; }
  .record__meta-row--wide { grid-column: 1 / -1; }
  .record__meta-row dt { font-size: var(--fs-300); color: var(--color-text-muted); text-transform: uppercase; letter-spacing: 0.04em; }
  .record__meta-row dd { font-weight: 600; margin-top: 0.1rem; overflow-wrap: break-word; }

  .record__body :global(h2) { color: var(--color-primary); margin-top: 2rem; }
  .record__body :global(h3) { margin-top: 1.5rem; }
  .record__body :global(ul), .record__body :global(ol) { padding-left: 1.25rem; }
  .record__body :global(a) { color: var(--color-link); }
  .record__body :global(img) { border-radius: var(--radius); border: 1px solid var(--color-border); }
</style>
