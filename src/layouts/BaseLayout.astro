---
// BaseLayout.astro — învelișul comun al tuturor paginilor.
// M1: Seo + skip-link + slot. Header/Footer reale vin la M2 (acum placeholdere minime).
import "../styles/global.css";
import Seo from "../components/Seo.astro";
import { SITE } from "../data/site";
import { useTranslations, switchLangPath, getAltLang, languages } from "../i18n/utils";
import type { Lang } from "../i18n/ui";

interface Props {
  title: string;
  description?: string;
  lang: Lang;
  image?: string;
  type?: "website" | "article";
  noindex?: boolean;
  jsonLd?: Record<string, unknown>;
}

const { title, description, lang, image, type, noindex, jsonLd } = Astro.props;
const t = useTranslations(lang);
const altLang = getAltLang(lang);
const altUrl = switchLangPath(Astro.url, altLang);
const homeUrl = `/${lang}/`;
const year = new Date().getFullYear();
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <Seo
      title={title}
      description={description}
      lang={lang}
      image={image}
      type={type}
      noindex={noindex}
      jsonLd={jsonLd}
    />
  </head>
  <body>
    <a class="skip-link" href="#main">{t("a11y.skipToContent")}</a>

    {/* ───── Placeholder M1 — înlocuit de <Header /> la M2 ───── */}
    <header class="ph-header">
      <div class="container ph-header__inner">
        <a class="ph-brand" href={homeUrl}>{SITE.name[lang]}</a>
        <a class="ph-lang" href={altUrl} hreflang={altLang} lang={altLang}>
          {languages[altLang]}
        </a>
      </div>
    </header>

    <main id="main">
      <slot />
    </main>

    {/* ───── Placeholder M1 — înlocuit de <Footer /> la M2 ───── */}
    <footer class="ph-footer">
      <div class="container">
        <p>© {year} {SITE.name[lang]}. {t("footer.rights")}</p>
      </div>
    </footer>
  </body>
</html>

<style>
  /* Stiluri placeholder (M1) — vor fi scoase la M2 odată cu Header/Footer reale. */
  .ph-header {
    border-bottom: 1px solid var(--color-border);
    background: var(--color-surface);
  }
  .ph-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding-block: 1rem;
  }
  .ph-brand {
    font-family: var(--font-serif);
    font-weight: 700;
    font-size: var(--fs-500);
    color: var(--color-primary);
    text-decoration: none;
  }
  .ph-lang {
    font-size: var(--fs-300);
    color: var(--color-text-muted);
  }
  .ph-footer {
    margin-top: 4rem;
    padding-block: 2rem;
    border-top: 1px solid var(--color-border);
    background: var(--color-surface-alt);
    color: var(--color-text-muted);
    font-size: var(--fs-300);
  }
</style>
