---
// Arhivă expoziții RO.
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Section from "../../../components/Section.astro";
import ExpozitiiList from "../../../components/collections/ExpozitiiList.astro";
import { useTranslations } from "../../../i18n/utils";
const lang = "ro" as const;
const t = useTranslations(lang);
---
<BaseLayout title={t("nav.exhibitions")} lang={lang}>
  <Section eyebrow={t("nav.exhibitions")} title={t("exh.calendar")} intro={t("exh.intro")}>
    <ExpozitiiList lang={lang} />
  </Section>
</BaseLayout>
